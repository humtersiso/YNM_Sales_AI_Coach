# 可選：話術 Excel 完整路徑。未設定時使用 web/data/ 內預設檔名（見 data/README.md）
# EXCEL_MAIN_PATH="C:\\path\\to\\AI話術演練表.xlsx"
# EXCEL_INCOMING_PATH="C:\\path\\to\\Demo話術演練資料.xlsx"

# --- BigQuery：話術演練 staging 匯入（/api/ingest/script-drills）---
# 必填其一：BIGQUERY_PROJECT_ID 或 GOOGLE_CLOUD_PROJECT
# BIGQUERY_PROJECT_ID=your-gcp-project
# BIGQUERY_DATASET=sales_training_poc
# BIGQUERY_TABLE_SCRIPT_DRILLS=script_drills_staging

# --- 訓練素材匯入（多車款 product_line）---
# TRAINING_MATERIALS_ROOT=C:\path\to\training-materials
# 單車款目錄例：...\training-materials\xtrail-ice
# SALES_CHAT_PRODUCT_LINE=xtrail-ice
# BIGQUERY_TABLE_KNOWLEDGE=v_sales_knowledge
# BIGQUERY_USE_KNOWLEDGE_VIEW=true
# 相容舊名：XTRAIL_ICE_SOURCE_ROOT
# 認證：本機請設定 GOOGLE_APPLICATION_CREDENTIALS 指向服務帳號 JSON，或使用 gcloud auth application-default login
# GOOGLE_APPLICATION_CREDENTIALS=C:\secrets\sa.json

# --- 銷售助手知識檢索（RAG / BQ 可切換）---
# SALES_KNOWLEDGE_BACKEND=rag
# RAG_PROJECT_ID=gen-lang-client-0927009312
# RAG_LOCATION=global
# 三語料庫（Agent Search data store 完整路徑，見 AI Applications Console）
# RAG_DATASTORE_SALES_SCRIPT=projects/PROJECT/locations/global/collections/default_collection/dataStores/QA_STORE_ID
# RAG_DATASTORE_COMPETITOR=projects/PROJECT/locations/global/collections/default_collection/dataStores/COMPETITOR_STORE_ID
# RAG_CORPUS_PRODUCT=projects/PROJECT/locations/asia-east1/ragCorpora/PRODUCT_CORPUS_ID
# Vertex RAG Engine hybrid search（僅 Weaviate 後端；ragManagedDb 不支援）
# alpha 0.4～0.5 略偏關鍵字，適合話術 QA
# RAG_VECTOR_DB=weaviate
# RAG_HYBRID_SEARCH_ALPHA=0.45
# 關閉：RAG_HYBRID_SEARCH=false
# 切回 BigQuery 檢索：SALES_KNOWLEDGE_BACKEND=bq
#
# --- Vertex RAG Grounding（對齊 Console Studio 一體化路徑）---
# SALES_CHAT_MODE=grounded
# 或 SALES_RAG_ANSWER_MODE=grounded（保留 hybrid 時僅切換生成路徑）
# RAG_GROUNDING_TOP_K=12
# GEMINI_GROUNDING_MODEL=gemini-2.5-flash
# SALES_RAG_GROUNDED_FALLBACK=true
# SALES_RAG_GROUNDING_IMPL=augment
# native=generateContent+retrieval；augment=augmentPrompt（asia-east1 預設）；auto=先 native 再 augment

# --- Conversational Analytics API（銷售助手 /api/sales/chat）---
# GEMINI_DATA_ANALYTICS_PROJECT=your-gcp-project
# GEMINI_DATA_ANALYTICS_LOCATION=asia-east1
# GEMINI_DATA_ANALYTICS_AGENT_ID=your-data-agent-id
# Data Agent :chat 思考模式（FAST 較快、THINKING 較完整；僅 data-agent 模式使用）
# GEMINI_DATA_AGENT_THINKING_MODE=FAST
# USE_MOCK_CHAT=false
# 銷售助手（建議測試用 agent = Function Calling）
SALES_CHAT_MODE=agent
# GEMINI_API_KEY=your-key
# GEMINI_MODEL=gemini-3.1-flash-lite
# 其他模式：hybrid | bq-fast | data-agent
# 題庫查無時顯示的聯絡窗口名稱
# SALES_SCRIPT_CONTACT=總部話術管理窗口
# 認證同 BigQuery：GOOGLE_APPLICATION_CREDENTIALS 或 ADC

# --- 權限與登入（MVP）---
# AUTH_SESSION_SECRET=change-this-long-random-secret
# APP_PUBLIC_URL=http://localhost:3000
# 首位管理員建立（npm run seed:admin）
# SEED_ADMIN_USERNAME=admin
# SEED_ADMIN_DISPLAY_NAME=系統管理員
# SEED_ADMIN_BRANCH=總部
# SEED_ADMIN_PASSWORD=YourAdmin123
