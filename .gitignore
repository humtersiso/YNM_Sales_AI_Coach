# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
deploy/cloudrun-test.secrets.yaml
deploy/cloudrun-prod.secrets.yaml
.deploy-tmp/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local POC data (incoming queue, legal reviews)
.data/
dev.db
*.db

# 測試 log（本地產生；保留目錄結構即可）
data/test-logs/*
!data/test-logs/.gitkeep

# 除錯腳本歸檔（僅本機參考，不進版控）
scripts/debug-archive/

# 建置殘留
source.tgz
*.tsbuildinfo

# 話術 Excel（請放於 data/，見 data/README.md）
/data/*.xlsx
/data/~$*

/app/generated/prisma
